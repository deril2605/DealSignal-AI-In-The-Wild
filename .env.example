LLM_API_KEY=
LLM_BASE_URL=https://<your-azure-openai-resource>.openai.azure.com/
LLM_MODEL=<your-azure-deployment-name>
LLM_API_VERSION=2024-02-15-preview

TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://agent.tinyfish.ai
TINYFISH_MAX_AGENTS=2
TINYFISH_BROWSER_PROFILE=lite
TINYFISH_PROXY_ENABLED=false
TINYFISH_PROXY_COUNTRY=
USE_TINYFISH_FOR_DISCOVERY=false
USE_TINYFISH_FALLBACK_DISCOVERY=true
USE_TINYFISH_FOR_FETCH_PRIMARY=false
USE_TINYFISH_FALLBACK_FETCH=true

DISCOVERY_RESULTS_PER_QUERY=2

MIN_ARTICLE_CHARS=700
MIN_SIGNAL_CONFIDENCE=0.55
MIN_SIGNAL_STRENGTH=0.50
MIN_EVIDENCE_CHARS=60

DATABASE_URL=sqlite:///./dealsignal.db

BLOB_SYNC_ENABLED=true
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<storage-account-name>;AccountKey=<storage-account-key>;EndpointSuffix=core.windows.net"
BLOB_CONTAINER=dealsignal
BLOB_DB_BLOB_NAME=state/dealsignal.db
CRON_EXPRESSION="30 16 * * *"
